---
import TagPill from '../components/TagPill.astro';
import '../global.css';
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
---

<BaseLayout pageTitle={`${frontmatter.title} | Lucas Timm`}>
  <article class="max-w-2xl mx-auto">
    <h2 class="text-2xl font-bold">{frontmatter.title}</h2>
    <p class="text-sm text-slate-700">{frontmatter.description}</p>
    <p>Published on {frontmatter.pubDate.slice(0, 10)}</p>
    <slot />
    <div class="flex gap-3 my-3 flex-wrap">
      <h3 class="font-bold text-slate-800">Tags</h3>
      {frontmatter.tags.sort().map((tag: string) => <TagPill tagName={tag} />)}
    </div>
  </article>
</BaseLayout>
