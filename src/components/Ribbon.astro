---
const { href } = Astro.props;
---

<div
  class="absolute -top-3 -right-3 aspect-square w-32 overflow-clip rounded-sm"
>
  <div class="absolute top-0 left-0 bg-sky-600 w-3 h-3"></div>
  <div class="absolute bottom-0 right-0 bg-sky-600 w-3 h-3"></div>
  <a
    href={href}
    class="absolute hover:bg-sky-400 transition-colors duration-150 font-bold bottom-0 right-0 bg-sky-300 block rotate-45 py-1 w-sqrt-2 text-center origin-bottom-right text-sm text-sky-800 tracking-wider font-bolder uppercase"
  >
    <slot />
  </a>
</div>
