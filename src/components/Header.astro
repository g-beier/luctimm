---
import Logo from './Logo.astro';
---

<div class="w-full px-2 py-1 absolute top-0">
  <header
    class="container mx-auto flex flex-row flex-nowrap justify-between items-center"
  >
    <Logo scale="48" />
    <nav>
      <ul class="flex flex-row flex-nowrap text-sm items-center sm:text-base">
        <li class="pl-2 sm:pl-4">
          <a
            href="/"
            class="hover:text-sky-200 active:text-sky-400 transition-color duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-4 focus-visible:ring-opacity-25 focus-visible:ring-offset-black"
            >Home</a
          >
        </li>
        <li class="pl-2 sm:pl-4"><a href="/curriculum">Curriculum</a></li>
        <li class="pl-2 sm:pl-4"><a href="/blog">Blog</a></li>
      </ul>
    </nav>
  </header>
</div>
